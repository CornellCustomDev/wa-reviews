{
    "name": "cornell-custom-dev/wa-reviews",
    "type": "project",
    "description": "A web app for completing and managing Cornell Web Accessibility reviews.",
    "license": "MIT",
    "repositories": {
        "flux-pro": {
            "type": "composer",
            "url": "https://composer.fluxui.dev"
        },
        "cornell-custom-dev/laravel-ldap": {
            "type": "vcs",
            "url": "https://github.com/CornellCustomDev/CD-LaravelLdap.git"
        }
    },
    "require": {
        "php": "^8.3",
        "ext-dom": "*",
        "ext-libxml": "*",
        "cornell-custom-dev/laravel-cu-auth": "^1.3",
        "cornell-custom-dev/laravel-ldap": "dev-main",
        "google/apiclient": "^2.19",
        "laravel/framework": "^13.11",
        "laravel/nightwatch": "^1.26",
        "laravel/pennant": "^1.23",
        "laravel/telescope": "^5.20",
        "laravel/tinker": "^3.0",
        "livewire/flux": "^2.14",
        "livewire/flux-pro": "^2.14",
        "livewire/livewire": "^4.3",
        "maatwebsite/excel": "^3.1",
        "maestroerror/laragent": "dev-main#45781ec",
        "openai-php/client": "^0.19",
        "prism-php/prism": "^0.100",
        "santigarcor/laratrust": "^8.5",
        "symfony/dom-crawler": "^7.4"
    },
    "require-dev": {
        "fakerphp/faker": "^1.24",
        "laravel/boost": "^2.4",
        "laravel/pint": "^1.29",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.9",
        "phpunit/phpunit": "^12.5",
        "spatie/laravel-ignition": "^2.12"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "pre-autoload-dump": "Google\\Task\\Composer::cleanup",
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": [],
            "providers": [
                "\\App\\Services\\GoogleApi\\GoogleApiServiceProvider"
            ]
        },
        "google/apiclient-services": [
            "Drive",
            "Sheets"
        ]
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
